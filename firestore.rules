rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net - Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }

    // --- User Profiles ---
    match /users/{userId} {
      // Schema validation helper
      function isValidUser(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 50
           && data.emoji is string && data.emoji.size() <= 2
           && data.friendId is string && data.friendId.size() <= 20
           && data.online is boolean
           && data.unreadCount is number;
      }

      // Anyone signed in can view other profiles (to find friends)
      allow get, list: if isSignedIn();
      
      // Users can only create their own profile
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      // Users can only update their own profile
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Only allow changing specific fields
        incoming().diff(existing()).affectedKeys().hasAny(['name', 'emoji', 'online', 'lastSeen', 'unreadCount'])
      );

      // Friend Requests (subcollection of users)
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        
        // Anyone can send a request to another user
        allow create: if isSignedIn() && incoming().status == 'pending';
        
        // Only the owner can accept/reject or delete their own notification
        allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
        allow delete: if isOwner(userId);
      }
    }

    // --- Chat Messages ---
    match /chats/{chatId} {
      // In Wifitel, chatId is constructed by combining two user UIDs
      function isParticipant() {
        return isSignedIn() && (chatId.contains(request.auth.uid));
      }

      allow get: if isParticipant();
      
      match /messages/{messageId} {
        allow read: if isParticipant();
        allow create: if isParticipant() && incoming().senderId == request.auth.uid;
      }
    }

    // --- Video Calls ---
    match /calls/{callId} {
      function isInCall(data) {
        return isSignedIn() && (data.callerId == request.auth.uid || data.receiverId == request.auth.uid);
      }

      allow get: if isSignedIn() && isInCall(existing());
      allow create: if isSignedIn() && isInCall(incoming());
      allow update: if isSignedIn() && isInCall(existing());
      allow delete: if isSignedIn() && isInCall(existing());
    }
  }
}
